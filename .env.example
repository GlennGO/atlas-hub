# Atlas Hub — Variables de entorno necesarias
# Renombrar a .env.local para desarrollo local
# En Coolify, agregar estas mismas variables en la config del app

# Atlas Hub - Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=https://supa-atlas.glenngo.com

# Sprint 5 — Hermes Agent (OpenRouter LLM)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ0eX...your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJ0eX...your_service_role_key_here

# La URL es pública (NEXT_PUBLIC_)
# El ANON_KEY es público (NEXT_PUBLIC_) — puede exponerse en el browser
# El SERVICE_ROLE_KEY es SECRETO — NUNCA en el browser, solo server-side
